{
  "expo": {
    "name": "GlowIQ",
    "slug": "glowiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.glowiq.app" },
    "android": { "adaptiveIcon": { "backgroundColor": "#2563EB" }, "package": "com.glowiq.app" },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router"],
    "scheme": "glowiq"
  }
}
